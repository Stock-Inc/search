{
  "title": "Search API",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Search requests",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{uri=\"/api/v1/search\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Average /search response time",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{uri=\"/api/v1/search\"}[5m])) / sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/search\"}[5m]))"
        }
      ]
    }
  ]
}
